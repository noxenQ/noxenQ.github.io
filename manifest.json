{
  "manifest_version": 2,
  "name": "NFC History Clearer",
  "version": "1.0",
  "description": "Clears browsing history when triggered by NFC tag",
  "permissions": [
    "browsingData",
    "webNavigation",
    "tabs",
    "notifications",
    "https://noxenq.github.io/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
