{
  "manifest_version": 3,
  "name": "NFC History Clearer",
  "version": "1.0",
  "description": "Clears browsing history when triggered by NFC tag",
  "permissions": [
    "browsingData",
    "webNavigation",
    "tabs",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://noxenq.github.io/*"
  ]
}
