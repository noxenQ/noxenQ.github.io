{
  "manifest_version": 2,
  "name": "NFC History Clearer",
  "version": "1.0",
  "description": "Clears browsing history when triggered by NFC tag",
  "permissions": [
    "browsingData",
    "webNavigation",
    "tabs",
    "notifications",
    "https://noxenq.github.io/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nfc-clearer@noxenq",
      "strict_min_version": "113.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
